# ===========================================
# roterdorn.de — Environment Variables
# ===========================================
# Kopiere diese Datei zu .env und trage die Werte ein.
# Variablen ohne "(optional)" sind zwingend erforderlich.


# ─── Datenbank (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=roterdorn
DATABASE_USERNAME=roterdorn
DATABASE_PASSWORD=CHANGE_ME_sicheres_passwort


# ─── Strapi Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337


# ─── Strapi Sicherheitsschlüssel ────────────────────────────────────────────
# Zufällige Strings (z. B. mit: openssl rand -base64 32)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=CHANGE_ME_random_string
ADMIN_JWT_SECRET=CHANGE_ME_random_string
JWT_SECRET=CHANGE_ME_random_string
TRANSFER_TOKEN_SALT=CHANGE_ME_random_string
ENCRYPTION_KEY=CHANGE_ME_random_string


# ─── Strapi API Tokens ──────────────────────────────────────────────────────
# Nach dem ersten Start im Strapi Admin unter Settings → API Tokens generieren.
STRAPI_API_TOKEN=CHANGE_ME_full_access_token
STRAPI_WRITE_TOKEN=CHANGE_ME_write_token


# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=https://roterdorn.de
# Interne Docker-URL für Server-seitige Anfragen (nicht im Browser sichtbar)
STRAPI_INTERNAL_URL=http://strapi:1337
# Geheimnis für Webhook-basierte ISR-Revalidierung (Next.js → /api/revalidate)
REVALIDATION_SECRET=CHANGE_ME_webhook_secret


# ─── Datenmigration ─────────────────────────────────────────────────────────
# Nur erforderlich, wenn das Migrations-Script (migration/migrate.js) ausgeführt wird.

# Verbindung zur Legacy-MySQL/WordPress-Datenbank
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_mysql_passwort
MYSQL_DATABASE=wp_legacy

# (optional) Pexels API-Key für automatische Titelbilder während der Migration.
# Nur erforderlich wenn generateImages: true in migration.config.json gesetzt ist.
# Kostenlos registrieren unter: https://www.pexels.com/api/
PEXELS_API_KEY=

# (optional) Abweichende Strapi-URL für die Migration (Standard: NEXT_PUBLIC_STRAPI_URL)
# STRAPI_MIGRATION_URL=http://localhost:1337/api
