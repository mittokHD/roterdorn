# ===========================================
# roterdorn.de — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Database (PostgreSQL) ---
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=roterdorn
DATABASE_USERNAME=roterdorn
DATABASE_PASSWORD=CHANGE_ME_secure_password

# --- Strapi ---
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=CHANGE_ME_random_string
ADMIN_JWT_SECRET=CHANGE_ME_random_string
JWT_SECRET=CHANGE_ME_random_string
TRANSFER_TOKEN_SALT=CHANGE_ME_random_string

# --- Strapi API Tokens (generate in Strapi Admin after first start) ---
STRAPI_API_TOKEN=           # Read-only token for frontend
STRAPI_WRITE_TOKEN=         # Full-access token for comment proxy

# --- Next.js ---
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
REVALIDATION_SECRET=CHANGE_ME_webhook_secret
