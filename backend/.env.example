# ===========================================
# Backend .env.example
# ===========================================
# NOTE: All configuration is managed via the ROOT .env file.
# This file documents which variables the backend expects.
# When running with Docker Compose, all values are injected from the root .env.
# When running standalone, copy the root .env to this directory.
#
# Required variables:
#   DATABASE_CLIENT, DATABASE_HOST, DATABASE_PORT, DATABASE_NAME,
#   DATABASE_USERNAME, DATABASE_PASSWORD,
#   HOST, PORT,
#   APP_KEYS, API_TOKEN_SALT, ADMIN_JWT_SECRET, JWT_SECRET,
#   TRANSFER_TOKEN_SALT, ENCRYPTION_KEY
